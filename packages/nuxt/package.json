{
  "name": "lukk-nuxt",
  "version": "0.7.0",
  "description": "Nuxt module for lukk (first-party Laravel JWT auth) + useLukkFetch, an auth-aware client for your own Laravel API — SSR / SPA / SSG, BFF or direct.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stsepelin/lukk-js.git",
    "directory": "packages/nuxt"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "lukk",
    "jwt",
    "auth",
    "laravel",
    "passkey",
    "2fa"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "build": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "typecheck": "nuxi typecheck playground",
    "test": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@nuxt/kit": "^3.13.0",
    "defu": "^6.1.4",
    "lukk-core": "workspace:*",
    "ofetch": "^1.5.1"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.4",
    "@nuxt/schema": "^3.13.0",
    "@vitest/coverage-v8": "^3.2.6",
    "h3": "^1.15.11",
    "nuxt": "^3.13.0",
    "vitest": "^3.2.6",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.5"
  }
}
